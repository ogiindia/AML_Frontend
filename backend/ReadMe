SELECT
    ul.*
FROM 
    ngp_user_login ul
JOIN 
    ngp_user_profile up ON ul.profile_id = up.profile_id
JOIN 
    ngp_group_users gu ON gu.grp_id = up.profile_id
JOIN 
    ngp_group_tb gt ON gt.grp_id = gu.grp_id
JOIN 
    ngp_ent_group eg ON gt.grp_id = eg.grp_id
JOIN 
    ngp_ent_master_tb em ON em.id = eg.id
